# Copy to .env and adjust for your environment.
#
# This file is gitignored (.env*). Keep it out of version control —
# never commit credentials or host-specific absolute paths.
#
# ONLY 4 variables need to live in the environment. Everything else
# (LLM API key, ComfyUI server URL/token, news config, message config,
# personas, workflows, RSS sources, etc.) is stored in the database
# and edited via /admin/config or the relevant admin page.
#
# DATABASE_URL — SQLite URL for Prisma + libsql.
#   - Relative path (recommended): "file:./dev.db" — resolves against
#     process.cwd(), so the server must be started from the project root.
#   - Absolute path only if you need a fixed DB location.
#   - Falls back to "file:./dev.db" in prisma.config.ts when unset.
DATABASE_URL="file:./dev.db"

# ADMIN_PASSWORD — the password for /admin/login. Cannot live in the DB
# because the login route needs it to mint the session cookie BEFORE
# any DB read. Must be ≥ 8 characters; shorter values are rejected.
ADMIN_PASSWORD=""

# WS_BROADCAST_TOKEN — shared secret between the Next.js process and
# the standalone ws-server (ws-server/index.ts). The ws-server does
# NOT have DB access, so this secret cannot live in the DB. The HTTP
# broadcast endpoints (POST /broadcast, /flush, /broadcast-message)
# return 503 when this is unset.
WS_BROADCAST_TOKEN=""

# WS_PORT — port the ws-server process binds for browser WebSocket
# connections (/messages, /audio). Plain ws:// only — TLS is the
# reverse proxy's job. Default 8080.
WS_PORT=8080

# WS_HTTP_PORT — port the ws-server's loopback HTTP broadcast API
# binds (Next.js posts here from inside the same host). Default 8081.
# Bound to 127.0.0.1 only — never reachable from outside the host.
WS_HTTP_PORT=8081

# NEXT_PUBLIC_WS_URL — full ws:// or wss:// base URL the BROWSER
# connects to for /messages and /audio. NEXT_PUBLIC_ means Next.js
# bakes this into the client bundle at BUILD TIME — you must
# `npm run build` again after changing it.
#
# Set this when the production WSS endpoint is on a different host
# or port than the ws-server's default :8080, e.g. when you front
# the ws-server with a Cloudflare origin rule, a Cloudflare Tunnel,
# or an nginx/caddy reverse proxy. Leave unset in dev to use the
# default ws://<page-hostname>:8080.
# Example for a Cloudflare-fronted prod deploy:
# NEXT_PUBLIC_WS_URL=wss://hualao.830038.xyz

# COMFYUI_WEBHOOK_SECRET — HMAC secret used to verify INCOMING webhook
# callbacks from ComfyUI (src/app/api/comfyui/webhook/route.ts). This
# is NOT the same as the bearer token in ComfyUIConfig.comfyuiToken
# (that one is what WE send to ComfyUI; this one is what ComfyUI
# sends back to us — opposite direction, separate secret).
COMFYUI_WEBHOOK_SECRET=""
