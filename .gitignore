# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.swc

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.pid


# env files (can opt-in for committing if needed)
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
*.env.bak
*.env.backup=======
# env files — all variants ignored; .env.example is committed as a template
.env*
!.env.example


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma client output (regenerated from schema)
/src/generated/prisma

# Local SQLite databases — dev.db at the repo root is the live one used
# by `prisma`. The src/dev.db copy is a stray. Keep neither in git.
*.db
*.sqlite
*.sqlite3
/src/dev.db

# uploaded reference audio (admin workflow uploads)
/public/uploads/


# TTS voice-clone reference samples (proprietary voice data, kept locally)
/workflows/*.flac
/workflows/*.mp3
/workflows/*.wav
/workflows/*.ogg
/workflows/*.m4a


# Internal-only project documents (not for the public repo)
/PRD.md
/PRD-live-engine.md
/omnivoice-tts-ComfyUI.md
/AGENTS.md
/CLAUDE.md

# WebSocket manual-test page route
/src/app/ws-test/

# Claude Code local-only state (per-machine settings, task scratch files)
/.claude/settings.local.json
**/settings.local.json

# Playwright MCP test artifacts (logs, page snapshots, screenshots)
/.playwright-mcp/

# Server process output captures (set by some dev launchers)
.server-err.txt
.server-out.txt

# Editor / IDE workspace state
/.vscode/
/.idea/

# Build / cache dirs (created by Next 15 / Turbopack / various tooling)
/dist/
/.turbo/
/.cache/
/tmp/
/temp/

# SQLite WAL and shared-memory files (companions to dev.db)
*.db-shm
*.db-wal

# Playwright MCP auto-generated test artifacts (screenshots, page states)
/.playwright-mcp/

# Script-generated screenshots and visual test artifacts
/scripts/*.png


# Runtime log files written at the project root when `npm start`/`npm run
# dev` is launched in a way that captures stdout/stderr. The project's
# launcher used to write `.server-out.txt` + `.server-err.txt`; if a new
# variant appears, this glob catches it.
.server-*.txt
*.pid
*.seed
*.pid.lock

# Editor / shell backup files (vim, emacs, JetBrains, VS Code crash
# dumps, etc.). These often contain excerpts of source the user is
# editing — sometimes including secrets from .env that were open in the
# editor — so ignore them by default.
*.bak
*.orig
*.rej
*.swp
*.swo
*~
.\#*
\#*\#
*.tmp
*.orig
*.dump

# OS / shell artifacts
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editor / IDE workspace settings (user-specific)
/.vscode/
/.idea/
*.swp
*.swo
*~
.cursor/
.aider*
.cody/
.clinerules/

# Build / cache artifacts that have appeared or might appear
/.next/
/.next-cache/
/out/
/build/
/.swc/
/.turbo/
/dist/
/.cache/

# Coverage / test reports (in case Jest/Vitest are added later)
/coverage/
/.nyc_output/
/junit.xml
/test-results/
/playwright-report/
/playwright/.cache/

# Logs that may land anywhere (not just project root)
/logs/
*.log

# Local package mirrors / pnpm caches
.pnpm-store/
.pnpm-debug.log*

# Yarn / npm scratch
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Misc
*.local
.history/
.idea_modules/
*.iml
*.ipr
*.iws


cookies.txt
